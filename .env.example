
# ============================================
# SERVER CONFIG
# ============================================
PORT=4000
API_VERSION=v1

# Set RUN_SEED=true only for the very first startup (creates the admin
# user below), then set it back to false and re-run
# `sudo docker compose up -d --build` so it doesn't reseed every restart.
RUN_MIGRATION=true
RUN_SEED=true

# ============================================
# DATABASE
# ============================================
# Hostname is "postgres" — the docker-compose service name — because the
# backend talks to it over the compose network, not localhost.
DATABASE_URL=postgres://dms_user:dms_password@postgres:5432/dms_db?sslmode=disable

# ============================================
# JWT AUTH
# ============================================
# Generate each with: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_2FA_CHALLENGE_SECRET=CHANGE_ME

# ============================================
# ADMIN SEED DATA (only used when RUN_SEED=true)
# ============================================
ADMIN_EMAIL=CHANGE_ME@example.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=CHANGE_ME
ADMIN_DEPARTMENT=IT

# ============================================
# MINIO
# ============================================
# Hostname is "minio" — the docker-compose service name, same reasoning
# as DATABASE_URL above.
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_PREFIX=user-

# ============================================
# RAG / AI PROVIDERS (optional — only needed for the chat/RAG feature)
# ============================================
# Which provider to use: ollama (default, free/local) | gemini | groq | anthropic
RAG_EMBED_PROVIDER=ollama
RAG_CHAT_PROVIDER=ollama

# Ollama runs on the HOST, not inside docker-compose. If you enable the
# optional Ollama install step in scripts/server-setup.sh, the backend
# container needs a route to the host — see the note it prints.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# ── Alternatives to Ollama (uncomment one instead) ──────────────────────
# RAG_EMBED_PROVIDER=gemini
# RAG_CHAT_PROVIDER=gemini
# GEMINI_API_KEY=

# RAG_CHAT_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001

# ============================================
# SMTP (optional — only for comment/share email notifications)
# ============================================
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
